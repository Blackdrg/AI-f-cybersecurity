# Face Recognition System Environment Variables

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/face_recognition
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
# DB_PASSWORD should be retrieved from HashiCorp Vault or AWS Secrets Manager in production
# For local development, set via environment or omit if using Vault
DB_NAME=face_recognition

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production
ENCRYPTION_KEY=your-32-byte-secret-key-here123456789012

# AWS (for KMS encryption)
AWS_REGION=us-east-1
KMS_KEY_ID=alias/face-recognition-key

# Azure AD (optional)
# AZURE_TENANT_ID=your-tenant-id

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_...  # Replace with your test key
STRIPE_PUBLISHABLE_KEY=pk_test_...  # Replace with your test key
STRIPE_WEBHOOK_SECRET=whsec_...  # Replace with your webhook secret

# OpenAI (for AI Assistant)
OPENAI_API_KEY=sk-...  # Replace with your API key

# InsightFace
INSIGHTFACE_CACHE_DIR=/app/models

# Frontend URL (for Stripe redirects)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true