# ============================================
# AI-f Enterprise Face Recognition Platform
# Complete Environment Configuration
# ============================================

# --------------------------------------------
# 1. DATABASE
# --------------------------------------------
# PostgreSQL connection URL (asyncpg format)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/face_recognition

# Individual DB parameters
DB_HOST=localhost
DB_PORT=5432
DB_NAME=face_recognition
DB_USER=postgres
DB_PASSWORD=password

# Connection pool tuning - critical for 10k+ RPS horizontal scaling
# With HPA up to 50 pods, set per-pod pool conservatively to avoid overwhelming DB.
# Recommendation for 10k RPS at 50 pods: avg 200 RPS per pod.
# With PostgreSQL max_connections ~1000, set per-pod max to 10-15.
#   DB_POOL_MAX_SIZE=12, DB_POOL_MIN_SIZE=4, PostgreSQL max_connections=600
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_SIZE=2
DB_REPLICA_POOL_MAX=5
DB_REPLICA_POOL_MIN=2

# Read replicas for horizontal read scaling (comma-separated host:port)
# DB_READ_REPLICAS=replica1:5432,replica2:5432

# --------------------------------------------
# 2. REDIS
# --------------------------------------------
# Redis URL for cache, pub/sub, Celery
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SSL=false

# --------------------------------------------
# 3. SECURITY & AUTHENTICATION
# --------------------------------------------
# JWT signing secret (MUST be 64 random bytes, stored in Vault in production)
JWT_SECRET=your-64-byte-base64-secret-change-in-production-and-store-in-vault

# JWT algorithm (HS256 or RS256)
JWT_ALGORITHM=HS256

# Token expiry in hours
JWT_EXPIRY_HOURS=1
JWT_REFRESH_EXPIRY_DAYS=30

# Encryption key for biometric data (AES-256, 32 bytes)
ENCRYPTION_KEY=your-32-byte-encryption-key-change-in-production

# OAuth2 - Azure AD (optional)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/callback/azure_ad

# OAuth2 - Google (optional)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/callback/google

# --------------------------------------------
# 4. PAYMENTS & BILLING
# --------------------------------------------
# Stripe API keys (test mode for staging, live mode for production)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_ENDPOINT_SECRET=whsec_...  # redundant with above, kept for backward compatibility

# Subscription plan IDs (Stripe)
STRIPE_PLAN_FREE_ID=price_free_123
STRIPE_PLAN_PRO_ID=price_pro_456
STRIPE_PLAN_ENTERPRISE_ID=price_enterprise_789

# --------------------------------------------
# 5. AI/LLM PROVIDERS
# --------------------------------------------
# OpenAI (for AI assistant)
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_PREMIUM_MODEL=gpt-4
PREMIUM_USER_EMAIL=daredevil0101a@gmail.com  # special-case for GPT-4 access

# Alternative LLM providers (optional)
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...

# --------------------------------------------
# 6. ML MODEL PATHS
# --------------------------------------------
# Model storage directories
INSIGHTFACE_CACHE_DIR=/app/models/insightface
MODEL_REGISTRY_PATH=/app/models/registry
ONNX_EXPORT_DIR=/app/models/onnx

# Model version override (for testing)
# DEFAULT_FACE_EMBEDDER_VERSION=v2.1.0
# DEFAULT_SPOOF_DETECTOR_VERSION=v1.3.0

# --------------------------------------------
# 7. EXTERNAL SERVICES
# --------------------------------------------
# Wikipedia API (for public enrichment)
WIKIPEDIA_API_URL=https://en.wikipedia.org/w/api.php

# Bing Search API (required for enrichment portal)
BING_API_KEY=...
# Note: bing_provider uses BING_API_KEY. Endpoint fixed to https://api.bing.microsoft.com/v7.0/search

# AWS (for KMS, S3, etc.)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_KMS_KEY_ID=alias/face-recognition-key
AWS_S3_BUCKET=models.ai-f.example.com

# --------------------------------------------
# 8. CORS & FRONTEND
# --------------------------------------------
# Allowed frontend origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com
FRONTEND_URL=http://localhost:3000

# --------------------------------------------
# 9. RATE LIMITING
# --------------------------------------------
# Global rate limit (requests per minute per user)
RATE_LIMIT_DEFAULT=100

# Endpoint-specific overrides
RATE_LIMIT_RECOGNIZE_FREE=50
RATE_LIMIT_RECOGNIZE_PRO=500
RATE_LIMIT_RECOGNIZE_ENTERPRISE=2000
RATE_LIMIT_ENROLL_FREE=10
RATE_LIMIT_ENROLL_PRO=100
RATE_LIMIT_ENROLL_ENTERPRISE=500
RATE_LIMIT_ADMIN_FREE=5
RATE_LIMIT_ADMIN_PRO=50
RATE_LIMIT_ADMIN_ENTERPRISE=200

# Rate limit window (seconds)
RATE_LIMIT_WINDOW=60

# Enable strict rate limiting (block on limit vs warning)
RATE_LIMIT_STRICT=false

# --------------------------------------------
# 10. CELERY & TASK QUEUES
# --------------------------------------------
# Celery broker URL (Redis)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Queue routing
CELERY_TASK_QUEUES=recognition,training,maintenance,federated
CELERY_TASK_DEFAULT_QUEUE=recognition

# Worker concurrency (0 = auto = CPU count)
CELERY_WORKER_CONCURRENCY=0

# Task acknowledge late (ack only after completion)
CELERY_ACKS_LATE=true

# Task timeout (seconds)
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# --------------------------------------------
# 11. MONITORING & OBSERVABILITY
# --------------------------------------------
# Prometheus metrics enabled
PROMETHEUS_ENABLED=true
PROMETHEUS_METRICS_PATH=/metrics
# Token to protect /metrics endpoint (required in production). Generate with: openssl rand -base64 32
METRICS_TOKEN=your-metrics-token-here

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/ai-f.log

# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=DETAILED  # SUMMARY, DETAILED, VERBOSE

# Sentry error tracking (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# --------------------------------------------
# 12. INFRASTRUCTURE
# --------------------------------------------
# Kubernetes deployment
K8S_NAMESPACE=face-recognition
K8S_REPLICAS_MIN=3
K8S_REPLICAS_MAX=50

# Docker
DOCKER_REGISTRY=ghcr.io/owner
DOCKER_IMAGE_BACKEND=ai-f-backend
DOCKER_IMAGE_FRONTEND=ai-f-frontend

# --------------------------------------------
# 13. FEATURE FLAGS
# --------------------------------------------
# Enable experimental features
FEATURE_ZKP_AUDIT=true
FEATURE_FEDERATED_LEARNING=true
FEATURE_HOMOMORPHIC_ENCRYPTION=true  # Uses TenSEAL simulation if false
FEATURE_VOICE_RECOGNITION=true
FEATURE_GAIT_ANALYSIS=true
FEATURE_BEHAVIORAL_ANALYSIS=true
FEATURE_EMOTION_DETECTION=true
FEATURE_AGE_GENDER=true
FEATURE_XAI=true
FEATURE_BAS_DETECTOR=true
FEATURE_CONSENT_VAULT=true

# Disable risky features if desired
FEATURE_EDGE_DEVICE_OTA=false
FEATURE_MULTI_CAMERA_FUSION=true

# --------------------------------------------
# 14. MODEL CONFIDENCE THRESHOLDS
# --------------------------------------------
# Default recognition threshold (0-1)
RECOGNITION_THRESHOLD=0.6

# Spoof detection threshold (0-1, reject if >)
SPOOF_THRESHOLD=0.5

# Minimum face size (pixels)
MIN_FACE_SIZE=40

# --------------------------------------------
# 15. BIOMETRIC TEMPLATE PROTECTION
# --------------------------------------------
# Non-invertible transform salt (for embedding perturbation)
BIOMETRIC_SALT_ROUNDS=1000

# Template update strategy: "static" | "adaptive" | "rolling"
TEMPLATE_UPDATE_STRATEGY=adaptive

# --------------------------------------------
# 16. AUDIT & COMPLIANCE
# --------------------------------------------
# External hash anchoring (Bitcoin/Ethereum) — NOT YET IMPLEMENTED
# HASH_ANCHOR_BLOCKCHAIN=bitcoin
# HASH_ANCHOR_API_KEY=...
# HASH_ANCHOR_SCHEDULE=daily  # how often to anchor

# GDPR compliance
GDPR_AUTO_DELETE_AFTER_DAYS=2555  # 7 years retention for audit

# BIPA consent required for enrollment
BIPA_CONSENT_REQUIRED=true

# --------------------------------------------
# 17. STORAGE
# --------------------------------------------
# Local file storage (for temporary uploads)
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE_MB=10

# S3 (for model storage, backups) — optional if using local
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# --------------------------------------------
# 18. EMAIL & NOTIFICATIONS
# --------------------------------------------
# SMTP (for alerts, billing emails)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Twilio (SMS alerts) — optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --------------------------------------------
# 19. DEVELOPMENT & DEBUG
# --------------------------------------------
# Set to true for verbose logging, mock models (faster startup)
DEBUG=false
DEBUG_MODELS=false  # Use random embeddings instead of real models

# Enable fake auth (skip JWT validation in dev)
FAKE_AUTH=false

# Disable rate limiting locally
DISABLE_RATE_LIMITS=false

# Auto-create org for first user (staging)
AUTO_CREATE_ORG_ON_SIGNUP=true

# --------------------------------------------
# 20. GEO-LOCATION POLICY
# --------------------------------------------
# GeoIP database path (MaxMind)
GEOIP_DATABASE_PATH=/app/data/GeoLite2-City.mmdb

# Blocked countries (comma-separated ISO codes)
GEO_BLOCK_COUNTRIES=XI,KP,IR

# Allowed countries (empty = all allowed except blocked)
GEO_ALLOW_ONLY=

# Timezone for time-based policies (default UTC)
SYSTEM_TIMEZONE=UTC

# --------------------------------------------
# 21. CORS
# --------------------------------------------
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Authorization,Content-Type,X-Requested-With

# --------------------------------------------
# 22. HOMOMORPHIC ENCRYPTION (HE)
# --------------------------------------------
# TenSEAL configuration — uses CKKS scheme for encrypted cosine similarity
HE_POLY_MODULUS_DEGREE=8192
HE_COEFF_MOD_BIT_SIZES=60,40,40,60
HE_SCALE=2^40

# Enable real HE (requires tenseal library)
# If false, uses simulation mode (deterministic pseudo-similarity)
HE_ENABLED=false

# --------------------------------------------
# 23. FEDERATED LEARNING
# --------------------------------------------
FL_ENABLED=true
FL_MIN_CLIENTS=3
FL_MAX_CLIENTS=100
FL_TIMEOUT_SECONDS=300
FL_NOISE_MULTIPLIER=1.0
FL_MAX_GRAD_NORM=1.0
FL_AGGREGATION_METHOD=fedavg  # fedavg | fedprox | krum

# Byzantine tolerance
FL_BYZANTINE_TOLERANCE=0  # 0 = disabled, 3 = tolerate up to 3 malicious

# --------------------------------------------
# 24. MODEL TRAINING
# --------------------------------------------
# Auto-retraining schedule (cron expression)
MODEL_RETRAIN_SCHEDULE=0 2 * * 0  # weekly Sundays at 2am UTC

# Minimum training samples required before retrain
MODEL_RETRAIN_MIN_SAMPLES=10000

# --------------------------------------------
# 25. PERFORMANCE TUNING
# --------------------------------------------
# Inference batch size (for async tasks)
INFERENCE_BATCH_SIZE=8

# GPU device ID (-1 = CPU)
CUDA_VISIBLE_DEVICES=-1

# ONNX Runtime settings
ORT_GPU_MEMORY_LIMIT=2048  # MB per session
ORT_EXECUTION_MODE=sequential  # sequential | parallel

# --------------------------------------------
# 26. TRUSTED EXECUTION ENVIRONMENT (TEE)
# --------------------------------------------
# Enable TEE enclave operations (requires AWS Nitro Enclaves)
# - Nitro: Native AWS hardware-isolated enclave (VSOCK communication)
# - SGX/SEV: Not yet implemented; would require hardware-specific drivers
# - mock: Development-only simulation (DO NOT USE IN PRODUCTION)
ENCLAVE_ENABLED=false
ENCLAVE_MODE=nitro  # "nitro" | "sgx" | "sev" | "mock"
ENCLAVE_VSOCK_PORT=5000
ENCLAVE_HEALTH_ENDPOINT=http://localhost:5000/health

# Strict mode: if true, enclave connection failures cause operation failure
# If false (dev), system falls back to non-TEE operation (less secure)
ENCLAVE_STRICT=true

# ============================================
# END OF CONFIGURATION
# ============================================

# --------------------------------------------
# 27. HARDWARE SECURITY MODULE (HSM)
# --------------------------------------------
# HSM backend: "software" | "cloud" | "none"
# - software: SoftHSM2 (local PKCS#11 software token)
# - cloud: AWS CloudHSM or Azure Key Vault Managed HSM
# - none: no HSM; software crypto only (dev only)
HSM_MODE=software

# PKCS#11 library path (SoftHSM)
# Linux: /usr/lib/softhsm/libsofthsm2.so
# macOS: /usr/local/lib/softhsm/libsofthsm2.dylib
# Windows: C:\Program Files\SoftHSM2\lib\softhsm2.dll
PKCS11_LIB=/usr/lib/softhsm/libsofthsm2.so

# SoftHSM token settings
HSM_TOKEN_LABEL=ai-f-token
HSM_PIN=1234

# SoftHSM key storage directory
HE_KEYS_DIR=/app/keys/he

# Cloud HSM (if HSM_MODE=cloud)
CLOUD_HSM_PROVIDER=aws  # aws | azure
CLOUD_HSM_REGION=us-east-1
CLOUD_HSM_KEY_ID=alias/ai-f-key

# Azure Key Vault (alternative)
AZURE_KEYVAULT_URL=https://your-vault.vault.azure.net/

# --------------------------------------------
# 28. BLOCKCHAIN ANCHORING (External ZKP Commitments)
# --------------------------------------------
# Anchor the root of the audit hash chain to a public blockchain (Bitcoin/Ethereum) for timestamping.
# This provides immutable proof of existence for audit trails.
ANCHOR_SERVICE_URL=  # Optional: custom microservice endpoint for anchoring
ANCHOR_SCHEDULE=hourly  # "hourly" | "daily" | "weekly" | "disabled"
ANCHOR_LEDGER=bitcoin  # Target ledger: bitcoin | ethereum | solana | custom

# --------------------------------------------
# 28. THREAT INTELLIGENCE FEEDS
# --------------------------------------------
# Configure external threat intel providers (leave empty to disable)
OTX_API_KEY=your-otx-api-key
MISP_URL=https://misp.example.com
MISP_API_KEY=your-misp-api-key
VIRUS_TOTAL_API_KEY=your-virustotal-key
ABUSEIPDB_API_KEY=your-abuseipdb-key
THREAT_INTEL_WEBHOOK_URL=https://hooks.example.com/threat-intel

# Demo mode: if true, providers return synthetic data (for UI demos without real keys)
THREAT_INTEL_DEMO_MODE=false
