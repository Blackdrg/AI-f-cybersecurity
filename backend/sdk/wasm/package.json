{
  "name": "@aif/sdk-wasm",
  "version": "2.1.0-scaffold",
  "description": "WebAssembly/TypeScript SDK for LEVI-AI Face Recognition",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "esbuild src/index.ts --bundle --outfile=dist/aiface.umd.js --format=umd --global-name=AIFaceSDK",
    "bundle:min": "esbuild src/index.ts --bundle --outfile=dist/aiface.umd.min.js --format=umd --global-name=AIFaceSDK --minify",
    "test": "jest",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "face-recognition",
    "biometrics",
    "ai",
    "wasm",
    "webassembly",
    "typescript",
    "sdk"
  ],
  "author": "LEVI-AI Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "peerDependencies": {},
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/owner/ai-f.git",
    "directory": "backend/sdk/wasm"
  }
}
