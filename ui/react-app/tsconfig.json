{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "es2015",
      "dom"
    ],
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "public/src"
  ]
}