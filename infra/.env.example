# .env - Copy to .env and edit secrets
DB_NAME=face_recognition
DB_USER=postgres
DB_PASSWORD=your_secure_password
JWT_SECRET=your_jwt_secret_key_32chars_min
ENCRYPTION_KEY=your_encryption_key_32chars_min
REDIS_URL=redis://redis:6379
USE_GPU=false
AWS_REGION=us-east-1
KMS_KEY_ID=alias/face-recognition-key
STRIPE_SECRET_KEY=sk_test_...
OPENAI_API_KEY=sk-...
FRONTEND_URL=http://localhost:3000
# For production, generate secrets: openssl rand -hex 32

