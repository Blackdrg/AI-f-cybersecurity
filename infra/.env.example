#!/bin/bash
# AI-f Infrastructure Setup Script
# Run this to set up the full development/production environment
set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}============================================================${NC}"
echo -e "${GREEN}  AI-f Infrastructure Setup${NC}"
echo -e "${GREEN}============================================================${NC}"

# Check prerequisites
echo -e "\n${YELLOW}Checking prerequisites...${NC}"

if ! command -v docker &> /dev/null; then
    echo -e "${RED}ERROR: Docker not found${NC}"
    exit 1
fi
echo "✓ Docker found: $(docker --version)"

if ! command -v docker-compose &> /dev/null && ! docker compose version &> /dev/null; then
    echo -e "${RED}ERROR: Docker Compose not found${NC}"
    exit 1
fi
echo "✓ Docker Compose found"

# Create necessary directories
echo -e "\n${YELLOW}Creating directories...${NC}"
mkdir -p infra/grafana/dashboards
mkdir -p infra/grafana/provisioning
mkdir -p infra/scripts
mkdir -p .benchmarks

# Environment setup
if [ ! -f ".env" ]; then
    echo -e "\n${YELLOW}Creating .env file...${NC}"
    cat > .env << ENVVARS
# Database Configuration
POSTGRES_PASSWORD=changeme_production_db
DB_PASSWORD=changeme_production_db
DB_USER=ai_f_user
DB_NAME=face_recognition
PG_MAX_CONNECTIONS=500
PG_SHARED_BUFFERS=512MB
PG_EFFECTIVE_CACHE=2GB
PG_WORK_MEM=64MB
PG_MAINTENANCE_MEM=256MB
DB_POOL_MAX_SIZE=15
DB_POOL_MIN_SIZE=3

# Redis Configuration
REDIS_PASSWORD=changeme_redis_password

# Application Secrets
JWT_SECRET=change-me-to-a-secure-random-string-min-32-bytes
ENCRYPTION_KEY=change-me-to-32-byte-encryption-key-here

# External Services
AWS_REGION=us-east-1
STRIPE_SECRET_KEY=sk_test_xxx
OPENAI_API_KEY=sk-xxx
BING_API_KEY=xxx
FRONTEND_URL=http://localhost:3000

# Monitoring
GRAFANA_PASSWORD=admin123
FLOWER_AUTH=admin:flower123

# Feature Flags
REDIS_SSL=false
ANCHOR_SCHEDULE=hourly
MODEL_RETRAIN_SCHEDULE="0 2 * * 0"
ENCLAVE_ENABLED=false
ENVIRONMENT=production
ENCRYPTION_AT_REST=true
AUDIT_LOGGING=true
RATE_LIMITING=true
VIRUS_SCANNING=true

# Redis Config
REDIS_URL=redis://:changeme_redis_password@redis-master:6379/0
REDIS_SENTINEL_MASTER=mymaster
REDIS_SENTINEL_HOSTS=redis-sentinel1:26379,redis-sentinel2:26379,redis-sentinel3:26379

# S3 for PITR backups
S3_BUCKET=ai-f-production-backups
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
S3_ENDPOINT=
BACKUP_RETENTION_DAYS=30

# Performance
DB_SLOW_QUERY_THRESHOLD_MS=100
DB_POOL_EXHAUSTION_THRESHOLD_PCT=90
DB_REPLICATION_LAG_THRESHOLD_SEC=5
DB_MONITOR_INTERVAL_SECONDS=30
DB_CONNECTION_TIMEOUT=15
DB_POOL_MAX_QUERIES=5000
DB_POOL_MAX_INACTIVE_LIFETIME=300
DB_POOL_HEALTH_CHECK_INTERVAL=30

# Logging
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true
SENTRY_DSN=

# CORS
CORS_ORIGINS=http://localhost:3000,https://app.ai-f.local

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG.xxx
SMTP_FROM=noreply@ai-f.com

# Slack Webhook for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Locust Load Testing
LOCUST_USERS=1000
LOCUST_SPAWN_RATE=100
LOCUST_DURATION=3600
LOCUST_HOST=http://backend:8000
ENVIRONMENT=production

# Grafana admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# Celery settings
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS=1000
CELERY_BROKER_TRANSPORT_OPTIONS_VISIBILITY_TIMEOUT=3600

# API Rate Limiting
API_RATE_LIMIT=100/minute
AUTH_API_RATE_LIMIT=20/minute

# Session Config
SESSION_MAX_AGE_SECONDS=86400
SESSION_REFRESH_EACH_REQUEST=true

# File upload limits
MAX_UPLOAD_SIZE=10485760
MAX_IMAGE_SIZE=5242880

# Feature Toggles
ENABLE_SPOOF_DETECTION=true
ENABLE_VOICE_RECOGNITION=true
ENABLE_GAIT_ANALYSIS=true
ENABLE_FEDERATED_LEARNING=true
ENABLE_BLOCKCHAIN_ANCHORING=true
ENABLE_REAL_TIME_ALERTS=true
ENABLE_DSAR_AUTOMATION=true
ENABLE_AUDIT_HASH_CHAIN=true
ENABLE_MODEL_DRIFT_DETECTION=true
ENABLE_RISK_SCORING=true
ENABLE_MULTI_FACTOR_AUTH=true
ENABLE_OFFLINE_MODE=true
ENABLE_EDGE_COMPUTING=true
ENABLE_ENCLAVE_PROCESSING=false

# Background Task Schedules
MODEL_HEALTH_CHECK_SCHEDULE="0 * * * *"
AUDIT_CHAIN_CHECK_SCHEDULE="0 2 * * *"
FEDERATED_LEARNING_SCHEDULE="0 3 * * *"
SESSION_CLEANUP_SCHEDULE="30 */6 * * *"
BIAS_REPORT_SCHEDULE="0 9 * * *"
USAGE_AUDIT_SCHEDULE="0 2 * * *"
DATA_RETENTION_SCHEDULE="0 4 * * *"
CACHE_INVALIDATION_SCHEDULE="*/15 * * * *"
DB_VACUUM_SCHEDULE="0 1 * * 0"

# Retention periods
SESSION_DATA_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=365
ALERT_RETENTION_DAYS=90
BIOMETRIC_DATA_RETENTION_YEARS=5
CONSENT_RECORD_RETENTION_YEARS=5
VIDEO_RETENTION_DAYS=30
BACKUP_RETENTION_DAYS=30
WAL_RETENTION_DAYS=7

# API Versioning
API_VERSION=v1
API_TITLE=AI-f Face Recognition API
API_DESCRIPTION=Professional face recognition and identity management platform
ENVIRONMENT=production

# Rate Limiting Store
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_STORAGE_URL=redis://:changeme_redis_password@redis-master:6379/1