  faiss:
    image: faiss/faiss:gpu
    command: faiss_index_server /faiss/index --host 0.0.0.0 --port 50051 --enable-grpc
    volumes:
      - faiss_index:/faiss/index
    ports:
      - "50051:50051"
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 1
              capabilities: [gpu]
    depends_on:
      - backend
