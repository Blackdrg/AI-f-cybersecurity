# --- Core Infrastructure ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=ai_f_user
DB_PASSWORD=changeme
DB_NAME=face_recognition
REDIS_URL=redis://localhost:6379/0

# --- Security ---
JWT_SECRET=your-super-secret-key-change-it
ENCRYPTION_KEY=32-character-encryption-key-for-biometrics
SENTRY_DSN=

# --- Biometric Engine ---
MODEL_PATH=/app/models
CONFIDENCE_THRESHOLD=0.4
SPOOF_CHECK_ENABLED=true
ENABLE_MULTI_MODAL=true

# --- SaaS & Billing ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:3000

# --- Compliance & External Anchoring ---
LEDGER_ANCHOR_ENABLED=true
ANCHOR_INTERVAL_SEC=3600
FIPS_MODE=false

# --- Development / Demo ---
REACT_APP_ENABLE_DEMO=true
REACT_APP_DEMO_EMAIL=demo@example.com
REACT_APP_DEMO_PASSWORD=password
NODE_ENV=development

# --- External AI Providers ---
OPENAI_API_KEY=
BING_SEARCH_KEY=
WIKIPEDIA_API_USER_AGENT=AI-f-Bot/1.0
